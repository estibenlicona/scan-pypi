# =========================================
# PyPI Scanner — Configuración de entorno
# =========================================
# Copia este archivo a .env y ajusta lo que necesites.
# Todas las variables son opcionales: tienen valores por defecto.

# -------------------------
# Reglas de negocio
# -------------------------
# Años desde la última publicación para considerar un paquete "mantenido"
MAINTAINED_YEARS=2

# Licencias bloqueadas (separadas por comas). Un paquete con alguna de estas se rechaza.
BLOCKED_LICENSES=GPL,GPL-2.0,GPL-3.0,LGPL,LGPL-2.0,LGPL-2.1,LGPL-3.0,AGPL,AGPL-3.0

# -------------------------
# Autenticación GitHub (opcional, muy recomendado)
# -------------------------
# PAT de GitHub para subir el rate limit de 60 a 5000 req/hora.
# Crear en: https://github.com/settings/tokens (sin scopes para repos públicos)
GITHUB_TOKEN=

# -------------------------
# Feed privado de PyPI (opcional)
# -------------------------
# URL de un índice privado, p. ej. Azure DevOps Artifacts:
# https://<org>.pkgs.visualstudio.com/<proj>/_packaging/<feed>/pypi/simple/
PRIVATE_INDEX_URL=

# Personal Access Token para autenticar contra el feed privado.
# Azure DevOps: https://dev.azure.com/<org>/_usersSettings/tokens (scope: Packaging > Read)
PRIVATE_INDEX_PAT=

# Habilita prereleases al resolver dependencias con uv (`--prerelease=allow`).
UV_ALLOW_PRERELEASE=false

# -------------------------
# Caché (opcional)
# -------------------------
CACHE_ENABLED=true
CACHE_DIRECTORY=.cache
CACHE_TTL_HOURS=24

# -------------------------
# HTTP / APIs (opcional)
# -------------------------
API_REQUEST_TIMEOUT=10

# -------------------------
# Reporte (opcional)
# -------------------------
REPORT_OUTPUT_PATH=consolidated_report.json

# -------------------------
# Logging (opcional)
# -------------------------
# Nivel: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Formato: text o json
LOG_FORMAT=text
